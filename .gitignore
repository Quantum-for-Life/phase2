# Compile artefacts -- every .o, .d, binary, and the
# shared library lands under build/<srcdir>/.
build/

# Editor scratch and IDE state
*.bak
*.swp
.idea/
.vscode/

# Python
.venv/
venv/
__pycache__/
*.egg-info/

# Runtime outputs (logs, intermediate HDF5)
*.log
simul.log
simul.h5*

# Bench records (per-host JSONL, accumulates across runs)
bench/runs/

# Misc local
tmp/
.claude/
